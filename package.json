{
  "name": "kexari-lens",
  "displayName": "Kexari Lens",
  "description": "Visual element inspector and React context extractor for Next.js",
  "version": "0.1.1",
  "publisher": "shifros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shifros/Kexari-Lens.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kexariLens.start",
        "title": "Kexari Lens: Start Inspector"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:proxy": "npm run compile && node scripts/test-proxy.mjs",
    "package": "npm run compile && vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.0",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/source-map": "^0.5.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  }
}
